# Copy to .env to override defaults. All keys are optional.
# JARVIS_DATA_DIR=~/.jarvis
# JARVIS_WHISPER_MODEL=small.en
# JARVIS_WAKE_WORD=hey_jarvis_v0.1
# JARVIS_OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
#
# Phase 3 (web search). Default provider is keyless DuckDuckGo.
# JARVIS_SEARCH_PROVIDER=ddg
# JARVIS_SEARCH_MCP_CMD=uvx duckduckgo-mcp-server
# Only needed if you switch providers — paste the value in .env, not here:
# JARVIS_TAVILY_API_KEY=
# JARVIS_BRAVE_API_KEY=
